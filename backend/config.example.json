{
  "server": {
    "port": 3000,
    "environment": "development"
  },
  "database": {
    "engine": "postgres",
    "poolMax": 20,
    "idleTimeoutMillis": 10000
  },
  "redis": {
    "host": "localhost",
    "port": 6379,
    "rateLimit": {
      "capacity": 100,
      "refillRate": 10
    }
  },
  "logging": {
    "level": "info"
  }
}
